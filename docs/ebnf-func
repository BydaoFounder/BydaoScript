(* Определение функции *)

func = ["pub"] ["immut"] "func" func_name "(" [ func_arg { "," func_arg } ] ")" [ ":" ret_type ] "{" block "}

func_arg = [ "out" ] arg_name [":" arg_type { "|" arg_type } ] [ "=" const ]

func_name = identifier (* имя функции *)

arg_name = identifier (* имя переменной - аргумента функции *)

arg_type = identifier (* тип аргумента функции, если не указан - может быть любой *)

ret_type = identifier (* тип возвращаемого значения, если не указан - функция ничего не возвращает *)

const = number | string | array | null | false | true

(*
Пояснения:

"pub" - сокращение от слова "public". Сообщает, что функция является "публичной",
        т.е. вызов/использование функции доступен из-вне модуля, в котором она
        определена на верхнем уровне области видимости

"immut" - сокращение от слова "immutable". Сообщает, что функция не изменяет
          внутреннее состояние объекта

"out" - выходной аргумент функции. Присвоение или изменение аргумента изменяет
        соответствующее значение во-вне функции. Аргументы без признака "out"
        доступны только для чтения. Какое-либо присвоение или изменение
        аргументов без "out" запрещено

Требования к компилятору:

1. Обращение к функции в тексте модуля возможно до ее объявления.

2. Обращение к функции (использование фнукции), объявленной в модуле,
   выполняется без указания какого-либо префикса, т.е., если в тексте встречается
   код "funcName()" - это обращение к функции модуля.

3. Функция, объявленная в модуле, имеет непосредственный доступ к переменныым,
   объявленным в этом модуле в той же области видимости.

4. Функция - объект типа "Func". Может быть передана как аргумент функции или
   присвоена переменной по имени как любой другой объект.

5. Публичные функции добавляются в мета-данные модуля.
*)
