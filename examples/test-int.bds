use Sys
/*
 * Набор тестов для "статических" методов типа "Int"
 */

// Int.range
var sum = 0
enum Int.range(0, 10) as v {
    sum += v
}
Sys.outln("Sum range 0..9 " + if sum == 45 { "success" } else {"failed"} )

// Int.parse
var n = Int.parse("123")
Sys.outln("Parse string '123' " + if n == 123 { "success" } else {"failed"} )

// Int.max/min
var a = 5
var b = 10
if Int.min(a,b) == a {
    Sys.outln("Int.min() success")
}
else {
    Sys.outln("Int.min() failed")
}
if Int.max(a,b) == b {
    Sys.outln("Int.max() success")
}
else {
    Sys.outln("Int.max() failed")
}

// Int.random
var r = Int.random(100,200)
if 100 <= r && r < 200 {
    Sys.outln("Int.ramdom(100,200) success")
}
else {
    Sys.outln("Int.ramdom(100,200) failed")
}

// Manual iterator using
var range = Int.range(5, 8).iter()
var success = true
while range.next() {
    var key = range.key
    var value = range.value
    if key == 0 && value == 5 ||
       key == 1 && value == 6 ||
       range.key == 2 && range.value == 7 {
        success = true
    }
    else {
        success = false
        break
    }
}
Sys.outln("Int.range(5, 8).iter() " + if success {"success"} else {'failed'} )

// Iteration
success = true
iter Int.range(5, 8) as it {
    var key = it.key
    var value = it.value
    if key == 0 && value == 5 ||
       key == 1 && value == 6 ||
       it.key == 2 && it.value == 7 {
        success = true
        next
    }
    else {
        success = false
        break
    }
}
if success {
    Sys.outln("iter Int.range(5, 8) success")
}
else {
    Sys.outln("iter Int.range(5, 8) failed")
}

// Enumeration
success = true
enum Int.range(5, 8) as val {
    if val != 5 && val != 6 && val != 7 {
        success = false
        break
    }
}
if success {
    Sys.outln("enum Int.range(5, 8) success")
}
else {
    Sys.outln("enum Int.range(5, 8) failed")
}

/*
 * Набор тестов для методов объекта типа "Int"
 */

//--------------------------------------------------
//  Convert to string

a = 123
var s = a.toString()
if s == '123' {
    Sys.outln("toString() success")
}
else {
    Sys.outln("toString() failed")
}
if s == a.toString(10) {
    Sys.outln("toString(10) success")
}
else {
    Sys.outln("toString(10) failed")
}
s = a.toHex()
if s == '7b' {
    Sys.outln("toHex() success")
}
else {
    Sys.outln("toHex() failed")
}
if a.toString(16) == a.toHex() {
    Sys.outln("a.toString(16) == a.toHex() success")
}
else {
    Sys.outln("a.toString(16) == a.toHex() failed")
}
s = a.toBin()
if s == '1111011' {
    Sys.outln("toBin() success")
}
else {
    Sys.outln("toBin() failed. Value = '" + s + "'" )
}

//  Abs
b = -a
if b.abs() == a.abs() {
    Sys.outln("abs() success. Value b = " + b )
}
else {
    Sys.outln("abs() failed")
}

//  Real
var c = a.toReal()
if c == 123.0 && a.toReal() == (123).toReal() {
    Sys.outln("toReal() success")
}
else {
    Sys.outln("toReal() failed")
}

//  Bool
if a {
    Sys.outln("if a success")
}
else {
    Sys.outln("if a failed")
}
if a.toBool() {
    Sys.outln("toBool() success")
}
else {
    Sys.outln("toBool() failed")
}

//  isNull
if ! a.isNull() {
    Sys.outln("isNull() success")
}
else {
    Sys.outln("isNull() failed")
}
